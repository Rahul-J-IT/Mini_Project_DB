{
  "datasets": [
    {
      "name": "897d37f6",
      "displayName": "Sales Data Cube",
      "queryLines": [
        "SELECT\n",
        "  dc.country_code,\n",
        "  dch.channel,\n",
        "  dp.product_name,\n",
        "  dp.category,\n",
        "  dcust.customer_id,\n",
        "  dcust.customer_name,\n",
        "  fs.date_key,\n",
        "  SUM(fs.line_total_usd) as revenue,\n",
        "  COUNT(fs.order_id) as order_count,\n",
        "  SUM(fs.quantity) as total_quantity,\n",
        "  SUM(fs.line_total) as revenue_local,\n",
        "  COUNT(DISTINCT fs.customer_key) as unique_customers\n",
        "FROM\n",
        "  fact_sales fs\n",
        "    JOIN dim_country dc\n",
        "      ON fs.country_key = dc.country_key\n",
        "    JOIN dim_channel dch\n",
        "      ON fs.channel_key = dch.channel_key\n",
        "    JOIN dim_product dp\n",
        "      ON fs.product_key = dp.product_key\n",
        "    JOIN dim_customer dcust\n",
        "      ON fs.customer_key = dcust.customer_key\n",
        "GROUP BY\n",
        "  dc.country_code,\n",
        "  dch.channel,\n",
        "  dp.product_name,\n",
        "  dp.category,\n",
        "  dcust.customer_id,\n",
        "  dcust.customer_name,\n",
        "  fs.date_key"
      ],
      "catalog": "novocart",
      "schema": "gold"
    }
  ],
